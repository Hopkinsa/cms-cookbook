# Example backend environment file.
# The backend prefers backend/.env and now also falls back to helper/dot.env.
# Keep FRONTEND_ORIGIN aligned with how you run the frontend:
# - http://localhost:4200 for `npm start`
# - http://localhost:3000 when the backend serves the built frontend
NODE_ENV=develpment
FRONTEND_ORIGIN=http://localhost:4200
SESSION_SECRET=replace-this-in-real-environments

# Optional bootstrap admin for first-time setup.
# If the configured bootstrap admin already exists, backend startup will
# sync that account to the full current bootstrap permission set.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_SURNAME=User
