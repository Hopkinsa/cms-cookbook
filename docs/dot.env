# Example backend environment file.
# The backend reads ./backend/.env by default via dotenv/config
# Copy this file to ./backend/.env or set DOTENV_CONFIG_PATH explicitly.

NODE_ENV=develpment
FRONTEND_ORIGIN=http://localhost:4200
SESSION_SECRET=replace-this-in-real-environments

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_SURNAME=User
